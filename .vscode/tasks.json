{
  "version": "2.0.0",
  "tasks": [
    {
      // Assemble a tiny site (the docs/ page + the three .lua sources the page
      // fetches, mirroring pages.yml) under /tmp and serve it over http on 8777.
      // wish.html must be served over http — opening it as file:// fails because
      // it fetch()es mini-tcl.lua / canvas.lua / tk.lua. Used as the preLaunchTask
      // for "Open wish …". Restarts cleanly so edits are always picked up.
      "label": "serve wish (http)",
      "type": "shell",
      "command": "D=/tmp/mini-tcl-wish-site; rm -rf \"$D\"; mkdir -p \"$D\"; cp ${workspaceFolder}/docs/* ${workspaceFolder}/mini-tcl.lua ${workspaceFolder}/canvas.lua ${workspaceFolder}/tk.lua \"$D\"/; (pkill -f 'http.server 8777' 2>/dev/null || true); sleep 0.3; cd \"$D\" && python3 -m http.server 8777",
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          { "regexp": ".", "file": 1, "line": 2, "column": 3, "message": 4 }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Serving HTTP",
          "endsPattern": "Serving HTTP"
        }
      },
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true }
    }
  ]
}
